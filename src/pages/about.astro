---
import Layout from "@/layouts/Layout.astro";
import Header from "@/sections/Header.astro";
import Footer from "@/sections/Footer.astro";
import Marquee from "@/components/Marquee.astro";
import { getLandingData } from "@/services/data.service";

const data = await getLandingData();
const { aboutData, headerData, footerData, meta } = data;
---

<Layout meta={{ ...meta, title: "About — Folex Agency" }}>
  <Header data={headerData} />
  <main class="flex flex-col w-full">

    <!-- Hero -->
    <section id="about-hero" class="w-full bg-black text-white pt-44 pb-32 px-8 md:px-24 border-b-2 border-white/10">
      <div class="max-w-6xl">
        <p class="text-xs font-black uppercase tracking-[0.3em] text-primary mb-8">About Us</p>
        <h1 class="text-6xl md:text-8xl lg:text-[6.5rem] font-black tracking-tighter leading-[0.88] mb-10 max-w-4xl">
          {aboutData.hero.title}
        </h1>
        <div class="flex items-center gap-x-6">
          <div class="w-16 h-0.5 bg-primary"></div>
          <p class="text-white/50 text-lg md:text-xl font-medium">{aboutData.hero.subTitle}</p>
        </div>
      </div>
    </section>

    <!-- Stats Bar -->
    <section class="w-full bg-primary py-0">
      <div class="max-w-6xl mx-auto px-8 md:px-24 grid grid-cols-3 divide-x-2 divide-black/20">
        <div class="py-10 px-6 first:pl-0">
          <p class="text-5xl font-black tracking-tighter text-black leading-none mb-1">12+</p>
          <p class="text-xs font-black uppercase tracking-widest text-black/50">Years Shipping</p>
        </div>
        <div class="py-10 px-6">
          <p class="text-5xl font-black tracking-tighter text-black leading-none mb-1">340+</p>
          <p class="text-xs font-black uppercase tracking-widest text-black/50">Projects Delivered</p>
        </div>
        <div class="py-10 px-6">
          <p class="text-5xl font-black tracking-tighter text-black leading-none mb-1">98%</p>
          <p class="text-xs font-black uppercase tracking-widest text-black/50">Client Retention</p>
        </div>
      </div>
    </section>

    <!-- Mission -->
    <section id="about-mission" class="w-full bg-white px-8 md:px-24 py-32 border-b border-gray-100">
      <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-24 items-start">
        <div>
          <p class="text-xs font-black uppercase tracking-[0.3em] text-black/30 mb-6">Mission</p>
          <h2 class="text-5xl md:text-6xl font-black tracking-tighter text-black leading-[0.9]">
            {aboutData.mission.title}
          </h2>
          <div class="w-12 h-1 bg-primary mt-8"></div>
        </div>
        <div class="md:pt-16">
          <p class="text-gray-600 text-lg leading-relaxed">
            {aboutData.mission.text}
          </p>
          <a href="/contact" class="inline-flex items-center gap-x-3 mt-10 text-xs font-black uppercase tracking-widest text-black hover:text-primary transition-colors group">
            Start a Project
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 group-hover:translate-x-1 transition-transform">
              <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Values -->
    <section id="about-values" class="w-full bg-black px-8 md:px-24 py-32">
      <div class="max-w-6xl mx-auto">
        <p class="text-xs font-black uppercase tracking-[0.3em] text-primary mb-4">What We Stand For</p>
        <h2 class="text-4xl md:text-5xl font-black tracking-tighter text-white mb-16 leading-tight">
          The Principles That<br />Drive Every Decision.
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-0 border border-white/10">
          {aboutData.values.map((value, i) => (
            <div class:list={[
              "group flex flex-col gap-y-6 p-10 border-white/10 hover:bg-primary transition-colors duration-300 cursor-default",
              i < aboutData.values.length - 1 ? "border-b md:border-b-0 md:border-r" : ""
            ]}>
              <span class="text-4xl font-black text-white/10 group-hover:text-black/20 transition-colors leading-none select-none">
                {String(i + 1).padStart(2, "0")}
              </span>
              <h3 class="text-xl font-black tracking-tight text-white group-hover:text-black transition-colors">
                {value.title}
              </h3>
              <p class="text-white/40 group-hover:text-black/60 transition-colors text-sm leading-relaxed">
                {value.description}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Team Image -->
    <section class="w-full h-[60vh] overflow-hidden relative">
      <img
        src="https://images.pexels.com/photos/3182812/pexels-photo-3182812.jpeg?auto=compress&cs=tinysrgb&w=1600"
        alt="Folex Agency team at work"
        class="w-full h-full object-cover object-center"
      />
      <div class="absolute inset-0 bg-black/40"></div>
      <div class="absolute bottom-12 left-8 md:left-24">
        <p class="text-white/60 text-xs font-black uppercase tracking-widest mb-2">The Collective</p>
        <p class="text-white text-3xl md:text-4xl font-black tracking-tighter">Obsessed with craft.<br />Addicted to results.</p>
      </div>
    </section>

    <Marquee dark={true} items={[
      "Built Different",
      "No Compromises",
      "Obsessively Crafted",
      "Results or Nothing",
      "Ship Fast, Ship Right",
      "Zero Mediocrity",
    ]} />

    <Footer data={footerData} />
  </main>
</Layout>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  #about-hero {
    opacity: 0;
    animation: fadeIn 0.9s ease-out forwards;
  }

  #about-mission {
    opacity: 0;
    animation: fadeIn 0.9s ease-out 0.1s forwards;
  }

  #about-values {
    opacity: 0;
    animation: fadeIn 0.9s ease-out 0.2s forwards;
  }
</style>
