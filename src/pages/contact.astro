---
import Layout from "@/layouts/Layout.astro";
import Header from "@/sections/Header.astro";
import Footer from "@/sections/Footer.astro";
import Icon from "@/components/Icon.astro";
import Action from "@/components/Action.astro";
import { getLandingData } from "@/services/data.service";
import type { Icon as IconType } from "@/config/landing.interface";

const data = await getLandingData();
const { contactData, headerData, footerData, meta } = data;
---

<Layout meta={{ ...meta, title: "Contact Us - Luna Landing" }}>
  <Header data={headerData} />
  <main class="flex flex-col justify-center items-center">
    <section class="w-full bg-black text-white py-32 mt-20 flex justify-center">
      <div class="w-3/4 text-center">
        <h1 class="text-5xl md:text-7xl font-black tracking-tighter leading-tight">
          {contactData.hero.title}
        </h1>
        <p class="mt-8 text-xl md:text-2xl text-white/80">
          {contactData.hero.subTitle}
        </p>
      </div>
    </section>

    <section class="w-full bg-white py-32 flex justify-center">
      <div class="w-3/4 grid md:grid-cols-2 gap-16">
        <div class="flex flex-col gap-y-12">
          <div>
            <h2 class="text-3xl md:text-4xl font-black tracking-tight text-gray-900 mb-12">
              Get in Touch
            </h2>

            <div class="flex flex-col gap-y-8">
              <div class="flex flex-col gap-y-2">
                <h3 class="text-sm font-bold text-gray-900/60 uppercase tracking-wider">
                  Email
                </h3>
                <a
                  href={`mailto:${contactData.info.email}`}
                  class="text-xl md:text-2xl font-semibold text-gray-900 hover:text-primary transition-colors"
                >
                  {contactData.info.email}
                </a>
              </div>

              <div class="flex flex-col gap-y-2">
                <h3 class="text-sm font-bold text-gray-900/60 uppercase tracking-wider">
                  Phone
                </h3>
                <a
                  href={`tel:${contactData.info.phone.replace(/\s/g, '')}`}
                  class="text-xl md:text-2xl font-semibold text-gray-900 hover:text-primary transition-colors"
                >
                  {contactData.info.phone}
                </a>
              </div>

              <div class="flex flex-col gap-y-4 mt-4">
                <h3 class="text-sm font-bold text-gray-900/60 uppercase tracking-wider">
                  Follow Us
                </h3>
                <div class="flex gap-x-4">
                  {
                    contactData.info.socials.map((social) => (
                      <Action
                        as="a"
                        href={social.href}
                        target="_blank"
                        class="bg-black text-white w-12 h-12 rounded-full flex items-center justify-center hover:bg-primary hover:text-black transition-all hover:scale-110"
                        title={social.label}
                      >
                        <Icon icon={social.icon as IconType} />
                      </Action>
                    ))
                  }
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-gray-50 p-10 rounded-3xl border border-gray-100 shadow-lg">
          <form class="flex flex-col gap-y-6">
            <div class="flex flex-col gap-y-2">
              <label
                for="name"
                class="text-sm font-bold text-gray-900 uppercase tracking-wider"
              >
                {contactData.form.nameLabel}
              </label>
              <input
                type="text"
                id="name"
                name="name"
                placeholder={contactData.form.namePlaceholder}
                required
                class="px-6 py-4 rounded-full border-2 border-gray-200 focus:border-primary focus:outline-none transition-all text-gray-900 font-medium bg-white"
              />
            </div>

            <div class="flex flex-col gap-y-2">
              <label
                for="email"
                class="text-sm font-bold text-gray-900 uppercase tracking-wider"
              >
                {contactData.form.emailLabel}
              </label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder={contactData.form.emailPlaceholder}
                required
                class="px-6 py-4 rounded-full border-2 border-gray-200 focus:border-primary focus:outline-none transition-all text-gray-900 font-medium bg-white"
              />
            </div>

            <div class="flex flex-col gap-y-2">
              <label
                for="message"
                class="text-sm font-bold text-gray-900 uppercase tracking-wider"
              >
                {contactData.form.messageLabel}
              </label>
              <textarea
                id="message"
                name="message"
                rows="6"
                placeholder={contactData.form.messagePlaceholder}
                required
                class="px-6 py-4 rounded-3xl border-2 border-gray-200 focus:border-primary focus:outline-none transition-all text-gray-900 font-medium resize-none bg-white"
              ></textarea>
            </div>

            <button
              type="submit"
              class="bg-primary text-black font-bold px-8 py-4 rounded-full hover:scale-105 hover:shadow-[0_0_20px_rgba(204,255,0,0.5)] transition-all text-lg mt-4"
            >
              {contactData.form.submitButton}
            </button>
          </form>
        </div>
      </div>
    </section>

    <Footer data={footerData} />
  </main>
</Layout>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  section {
    opacity: 0;
    animation: fadeIn 0.8s ease-in-out forwards;
  }

  section:nth-child(2) {
    animation-delay: 0.2s;
  }
</style>
