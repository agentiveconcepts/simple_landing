---
interface Props {
  items?: string[];
}

const { items = [
  "We Give Unparalleled Flexibility",
  "World-Class Design",
  "SEO Optimized",
  "Lightning Fast Performance",
  "Fully Accessible",
  "Modern Tech Stack",
] } = Astro.props;

const doubled = [...items, ...items];
---

<div class="w-full bg-primary overflow-hidden py-4 flex items-center border-y-2 border-black">
  <div class="marquee-track flex items-center gap-x-0 whitespace-nowrap">
    {doubled.map((item) => (
      <span class="flex items-center gap-x-3 pr-10">
        <span class="w-2 h-2 rounded-full bg-black inline-block shrink-0"></span>
        <span class="text-black font-black uppercase tracking-widest text-sm">{item}</span>
      </span>
    ))}
  </div>
</div>

<style>
  .marquee-track {
    animation: marquee 28s linear infinite;
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
</style>
