---
interface Props {
  items?: string[];
  dark?: boolean;
}

const { items = [
  "We Give Unparalleled Flexibility",
  "World-Class Design",
  "SEO Optimized",
  "Lightning Fast Performance",
  "Fully Accessible",
  "Modern Tech Stack",
], dark = false } = Astro.props;

const doubled = [...items, ...items];
---

<div class:list={["w-full overflow-hidden py-4 flex items-center border-y-2", dark ? "bg-black border-white/10" : "bg-primary border-black"]}>
  <div class="marquee-track flex items-center gap-x-0 whitespace-nowrap">
    {doubled.map((item) => (
      <span class="flex items-center gap-x-3 pr-10">
        <span class:list={["w-2 h-2 inline-block shrink-0", dark ? "bg-primary" : "bg-black"]}></span>
        <span class:list={["font-black uppercase tracking-widest text-sm", dark ? "text-white" : "text-black"]}>{item}</span>
      </span>
    ))}
  </div>
</div>

<style>
  .marquee-track {
    animation: marquee 28s linear infinite;
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
</style>
