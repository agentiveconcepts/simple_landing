---
import type { HTMLTag, Polymorphic } from "astro/types";

type actionTypes = "button" | "text" | "icon" | "default";

type Props<Tag extends HTMLTag> = Polymorphic<{ as: Tag }>;

const { as: Tag, class: className, type, ...props } = Astro.props;

const defaultStyles = {
  button:
    "px-6 py-3 text-sm md:text-base md:px-8 md:py-4 rounded-none text-center font-bold hover:scale-105 transition-all inline-block",
  text: "hover:opacity-70 hover:scale-105 transition-all",
  icon: "text-white hover:opacity-70 hover:scale-110 transition-all",
  default: "",
};

const baseClass = defaultStyles[type as actionTypes] ?? "";
---

<Tag class:list={[baseClass, className]} {...props}><slot /></Tag>
