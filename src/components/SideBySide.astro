---
import Icon from "@/components/Icon.astro";
import IconWrapper from "@/components/IconWrapper.astro";
import { ASSET_PREFIX } from "@/config/constants";
import type { Adventaje } from "@/config/landing.interface";

interface Props {
  data: Adventaje;
  reversed: boolean;
}

const { data, reversed } = Astro.props;
---

<article
  class=`flex justify-between gap-x-16 flex-col mb-24 md:mb-32 ${reversed ? "md:flex-row-reverse" : "md:flex-row"} items-center`
>
  <div class="md:w-3/4">
    <img src={ASSET_PREFIX + data.img} alt={data.imageAlt} class="w-full rounded-3xl shadow-xl" />
  </div>
  <div class="flex flex-col md:w-5/6 gap-y-6">
    <h3 class="text-3xl font-black tracking-tight md:text-5xl text-gray-900">{data.title}</h3>
    <p class="md:text-xl text-gray-900/80 leading-relaxed">{data.description}</p>
    <ul class="flex flex-col gap-y-6 mt-4">
      {
        data.checks.map((check) => (
          <li class="flex flex-row items-center gap-x-4 md:text-xl font-semibold text-gray-900">
            <IconWrapper>
              <Icon icon="CheckIcon" />
            </IconWrapper>
            {check}
          </li>
        ))
      }
    </ul>
  </div>
</article>
