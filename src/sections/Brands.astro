---
import Action from "@/components/Action.astro";
import Icon from "@/components/Icon.astro";
import type { BrandsData, Icon as IconType } from "@/config/landing.interface";

interface Props {
  data: BrandsData;
}

const { data } = Astro.props;
---

<section class="w-full bg-white py-14 border-y border-gray-100">
  <p class="text-xs font-bold uppercase tracking-[0.2em] text-gray-900/40 text-center mb-10">
    {data.title}
  </p>
  <div class="flex flex-wrap justify-center items-center gap-x-12 gap-y-6 px-8">
    {
      data.brands.map((brand) => (
        <Action
          as="a"
          href={brand.href}
          title={brand.label}
          target="_blank"
          class="opacity-40 grayscale hover:opacity-100 hover:grayscale-0 hover:scale-110 transition-all"
        >
          <Icon icon={brand.icon as IconType} />
        </Action>
      ))
    }
  </div>
</section>
