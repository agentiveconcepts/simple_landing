---
import Action from "@/components/Action.astro";

interface Props {
  data: {
    title: string;
    subTitle: string;
    primaryCta: string;
    secondaryCta: string;
    highlightedTitle?: string;
  };
}

const { data } = Astro.props;
---

<section id="hero-section" class="w-full min-h-screen bg-black text-white flex flex-col">
  <div class="flex flex-col md:flex-row flex-1 pt-20">
    <div class="flex flex-col justify-center px-8 md:px-16 lg:px-24 py-20 md:py-0 md:w-1/2 gap-y-8">
      <p class="text-xs font-bold uppercase tracking-[0.25em] text-primary">Digital Agency</p>
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-black tracking-tighter leading-[0.92]">
        {data.title}
        <span class="text-primary"> {data.highlightedTitle}</span>
      </h1>
      <p class="text-base md:text-lg text-white/60 max-w-md leading-relaxed">
        {data.subTitle}
      </p>
      <div class="flex flex-wrap gap-4">
        <Action
          as="a"
          type="button"
          class="bg-primary text-black font-bold hover:scale-105 hover:shadow-[0_0_24px_rgba(204,255,0,0.5)] transition-all"
          href="https://github.com/JimmyCamus/luna-landing"
          target="_blank"
        >
          {data.primaryCta}
        </Action>
        <Action
          as="a"
          type="button"
          class="bg-transparent text-white border border-white/30 font-semibold hover:border-white hover:bg-white/10 transition-all"
          href="https://github.com/JimmyCamus/luna-landing"
          target="_blank"
        >
          {data.secondaryCta}
        </Action>
      </div>

      <div class="flex gap-x-10 pt-4 border-t border-white/10 mt-4">
        <div>
          <p class="text-3xl font-black text-white">200+</p>
          <p class="text-xs text-white/50 uppercase tracking-widest mt-1">Projects Done</p>
        </div>
        <div>
          <p class="text-3xl font-black text-white">98%</p>
          <p class="text-xs text-white/50 uppercase tracking-widest mt-1">Client Satisfaction</p>
        </div>
        <div>
          <p class="text-3xl font-black text-white">12+</p>
          <p class="text-xs text-white/50 uppercase tracking-widest mt-1">Years Experience</p>
        </div>
      </div>
    </div>

    <div class="md:w-1/2 relative overflow-hidden min-h-[400px] md:min-h-0">
      <img
        src="https://images.pexels.com/photos/3184291/pexels-photo-3184291.jpeg?auto=compress&cs=tinysrgb&w=1200"
        alt="Team working creatively"
        class="w-full h-full object-cover object-center"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-black via-black/30 to-transparent md:block hidden"></div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  #hero-section {
    opacity: 0;
    animation: fadeIn 0.9s ease-out forwards;
  }
</style>
