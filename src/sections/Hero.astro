---
import Action from "@/components/Action.astro";

interface Props {
  data: {
    title: string;
    subTitle: string;
    primaryCta: string;
    secondaryCta: string;
    highlightedTitle?: string;
  };
}

const { data } = Astro.props;
---

<section id="hero-section" class="w-full flex flex-col items-center justify-center min-h-screen bg-black text-white pt-20 px-8 md:px-24 pb-24">
  <div class="max-w-4xl w-full flex flex-col items-center text-center">
    <p class="text-xs font-bold uppercase tracking-[0.25em] text-primary mb-8">Digital Agency</p>
    <h1 class="text-6xl md:text-8xl font-black tracking-tighter leading-[0.95] mb-10">
      {data.title}
      <span class="text-primary"> {data.highlightedTitle}</span>
    </h1>
    <p class="text-lg md:text-xl text-white/60 max-w-xl leading-relaxed mb-14">
      {data.subTitle}
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <Action
        as="a"
        type="button"
        class="bg-primary text-black font-bold hover:scale-105 hover:shadow-[0_0_24px_rgba(204,255,0,0.5)] transition-all"
        href="https://github.com/JimmyCamus/luna-landing"
        target="_blank"
      >
        {data.primaryCta}
      </Action>
      <Action
        as="a"
        type="button"
        class="bg-transparent text-white border border-white/30 font-semibold hover:border-white hover:bg-white/10 transition-all"
        href="https://github.com/JimmyCamus/luna-landing"
        target="_blank"
      >
        {data.secondaryCta}
      </Action>
    </div>
  </div>

  <div class="flex justify-center mt-20">
    <Action
      as="a"
      class="flex justify-center items-center animate-bounce bg-primary text-black rounded-full w-12 h-12 hover:shadow-[0_0_20px_rgba(204,255,0,0.5)] transition-all"
      href="#services-section"
      title="scroll down"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="2.5"
        stroke="currentColor"
        class="w-5 h-5"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3"></path>
      </svg>
    </Action>
  </div>
</section>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  #hero-section {
    opacity: 0;
    animation: fadeIn 0.9s ease-out forwards;
  }
</style>
