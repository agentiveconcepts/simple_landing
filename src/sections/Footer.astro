---
import Action from "@/components/Action.astro";
import Icon from "@/components/Icon.astro";
import type { FooterData, Icon as IconType } from "@/config/landing.interface";

interface Props {
  data: FooterData;
}

const { data } = Astro.props;
---

<footer
  class="flex flex-col justify-center text-center gap-y-8 pt-16 pb-8 bg-black text-white w-full"
>
  <section>
    <Action as="a" type="text" class="text-2xl md:text-3xl font-black tracking-tighter" href="/">
      {data.logo}
    </Action>
  </section>
  <section>
    <p class="md:text-lg text-white/80">
      {data.description}
    </p>
  </section>
  <section
    class="flex flex-row flex-wrap justify-center gap-x-6 px-4 md:px-0 md:text-lg font-medium"
  >
    {
      data.links.map((link) => (
        <Action as="a" type="text" href={link.href}>
          {link.label}
        </Action>
      ))
    }
  </section>
  <section class="mb-5 flex flex-row flex-wrap justify-center gap-x-4">
    {
      data.socials.map((social) => (
        <Action as="a" type="icon" href={social.href} title={social.icon}>
          <Icon icon={social.icon as IconType} />
        </Action>
      ))
    }
  </section>
</footer>
