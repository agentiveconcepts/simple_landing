---
import Action from "@/components/Action.astro";
import Icon from "@/components/Icon.astro";
import type { FooterData, Icon as IconType } from "@/config/landing.interface";

interface Props {
  data: FooterData;
}

const { data } = Astro.props;
---

<footer class="w-full bg-black text-white">
  <div class="bg-primary px-8 py-16 flex flex-col md:flex-row items-center justify-between gap-8 md:px-24">
    <h2 class="text-3xl md:text-5xl font-black tracking-tighter text-black text-center md:text-left max-w-xl leading-tight">
      Let's Work Together
    </h2>
    <Action
      as="a"
      type="button"
      class="bg-black text-white font-bold px-10 py-4 shrink-0 hover:bg-gray-900 transition-colors"
      href="/contact"
    >
      Get In Touch
    </Action>
  </div>

  <div class="px-8 md:px-24 pt-16 pb-8">
    <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-10 pb-12 border-b border-white/10">
      <div class="flex flex-col gap-y-4 max-w-xs">
        <Action as="a" class="text-xl font-black tracking-tighter text-white" href="/">
          {data.logo}
        </Action>
        <p class="text-sm text-white/60 leading-relaxed">
          {data.description}
        </p>
      </div>

      <nav class="flex flex-wrap gap-x-8 gap-y-4 md:gap-x-10">
        {
          data.links.map((link) => (
            <Action as="a" type="text" class="text-sm text-white/70 hover:text-white" href={link.href}>
              {link.label}
            </Action>
          ))
        }
      </nav>

      <div class="flex gap-x-3">
        {
          data.socials.map((social) => (
            <Action
              as="a"
              href={social.href}
              title={social.icon}
              class="w-10 h-10 rounded-none border border-white/20 flex items-center justify-center text-white/60 hover:text-white hover:border-white/60 transition-all"
            >
              <Icon icon={social.icon as IconType} />
            </Action>
          ))
        }
      </div>
    </div>

    <p class="pt-8 text-xs text-white/30 text-center md:text-left">
      &copy; {new Date().getFullYear()} {data.logo}. All rights reserved.
    </p>
  </div>
</footer>
