---
import Action from "@/components/Action.astro";
import type { HeaderData } from "@/config/landing.interface";

interface Props {
  data: HeaderData;
}

const { data } = Astro.props;
---

<header
  id="navbar"
  class="w-full transition duration-300 justify-center fixed h-20 z-50 hidden md:flex backdrop-blur-md bg-white/80"
>
  <nav aria-label="Main Navigation" class="flex flex-row items-center w-3/4">
    <div class="text-nowrap">
      <Action as="a" class="text-xl font-black tracking-tighter text-black" href="#">{data.logo}</Action>
    </div>
    <ul class="flex flex-row w-full justify-center gap-x-14">
      {
        data.links.map((item) => (
          <li class="text-base font-medium hover:scale-105 hover:text-primary transition-all">
            <Action as="a" href={item.href}>
              {item.label}
            </Action>
          </li>
        ))
      }
    </ul>
    <span></span>
  </nav>
</header>

<script>
  window.addEventListener("scroll", function () {
    const navbar = document.getElementById("navbar");
    if (!navbar) return;

    if (window.scrollY >= 20) {
      navbar.classList.remove("bg-white/80");
      navbar.classList.add("bg-white/95");
      navbar.classList.add("border-b");
      navbar.classList.add("border-b-gray-100");
      navbar.classList.add("shadow-sm");
    } else {
      navbar.classList.remove("bg-white/95");
      navbar.classList.remove("border-b");
      navbar.classList.remove("border-b-gray-100");
      navbar.classList.remove("shadow-sm");
      navbar.classList.add("bg-white/80");
    }
  });
</script>
