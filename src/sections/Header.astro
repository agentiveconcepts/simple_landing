---
import Action from "@/components/Action.astro";
import type { HeaderData } from "@/config/landing.interface";

interface Props {
  data: HeaderData;
}

const { data } = Astro.props;
---

<header
  id="navbar"
  class="w-full transition-all duration-300 justify-center fixed h-20 z-50 hidden md:flex backdrop-blur-md bg-black/80 border-b border-white/10"
>
  <nav aria-label="Main Navigation" class="flex flex-row items-center w-3/4 gap-x-12">
    <div class="text-nowrap shrink-0">
      <Action as="a" class="text-lg font-black tracking-tighter text-white" href="/">{data.logo}</Action>
    </div>
    <ul class="flex flex-row w-full justify-center gap-x-10">
      {
        data.links.map((item) => (
          <li class="text-sm font-medium text-white/80 hover:text-white transition-colors">
            <Action as="a" href={item.href}>
              {item.label}
            </Action>
          </li>
        ))
      }
    </ul>
    <div class="shrink-0">
      <Action
        as="a"
        type="button"
        class="bg-primary text-black text-sm font-bold px-5 py-2.5 hover:shadow-[0_0_16px_rgba(204,255,0,0.45)] hover:scale-105"
        href="/contact"
      >
        Get Started
      </Action>
    </div>
  </nav>
</header>

<script>
  window.addEventListener("scroll", function () {
    const navbar = document.getElementById("navbar");
    if (!navbar) return;

    if (window.scrollY >= 20) {
      navbar.classList.remove("bg-black/80");
      navbar.classList.add("bg-black/95");
      navbar.classList.add("shadow-lg");
    } else {
      navbar.classList.remove("bg-black/95");
      navbar.classList.remove("shadow-lg");
      navbar.classList.add("bg-black/80");
    }
  });
</script>
